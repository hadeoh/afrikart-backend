# Server
PORT=3000

# MongoDB — use local instance or override with Atlas URI
MONGO_URI=mongodb://localhost:27017/afrikart

# Sandbox API — keep configurable; never hardcode localhost in submissions
AFRIKART_BASE_URL=http://localhost:4000
AFRIKART_SECRET_KEY=sk_test_afrikart_secret
AFRIKART_PUBLIC_KEY=pk_test_afrikart_public
AFRIKART_WEBHOOK_SECRET=whsec_afrikart_secret

# How long a PROCESSING payout waits for a webhook before it's flagged UNCERTAIN (ms)
PAYOUT_UNCERTAINTY_THRESHOLD_MS=1800000
